
/* HERO OS RC1 — estabilização pré-produção
   Escopo: somente camada visual, consistência e estabilidade de componentes. */

:root{
  --hero-rc-transition: 180ms cubic-bezier(.2,.8,.2,1);
  --hero-rc-radius: 18px;
  --hero-rc-radius-sm: 12px;
  --hero-rc-line: rgba(148,163,184,.16);
  --hero-rc-surface: rgba(8,17,29,.72);
  --hero-rc-surface-strong: rgba(10,22,37,.88);
}

html[data-hero-os-visual],
html[data-hero-os-visual] body{
  overflow-x: hidden;
  scroll-behavior: smooth;
}

html[data-hero-os-visual] *{
  box-sizing: border-box;
}

html[data-hero-os-visual] body{
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
}

/* RC1: neutraliza elementos flutuantes legados sem afetar navegação oficial. */
html[data-hero-os-visual] .community-fab,
html[data-hero-os-visual] .hero-community-fab,
html[data-hero-os-visual] .hero-community-floating,
html[data-hero-os-visual] [data-community-fab],
html[data-hero-os-visual] [data-hero-floating-community],
html[data-hero-os-visual] #heroCommunityFloating,
html[data-hero-os-visual] #communityFab,
html[data-hero-os-visual] #heroCommunityAccessFixed,
html[data-hero-os-visual] #heroCommunityAccessFinal,
html[data-hero-os-visual] #heroCommunityAccessTop,
html[data-hero-os-visual] #heroTrainerCommunityCTA,
html[data-hero-os-visual] #heroTrainerCommunityStableCTA,
html[data-hero-os-visual] #heroTrainerCommunityInlineCTA,
html[data-hero-os-visual] .hero-trainer-community-inline-wrap,
html[data-hero-os-visual] .hero-trainer-community-inline-note{
  display: none !important;
  visibility: hidden !important;
  opacity: 0 !important;
  pointer-events: none !important;
  position: absolute !important;
  inset: auto auto auto -9999px !important;
  width: 0 !important;
  height: 0 !important;
  min-width: 0 !important;
  min-height: 0 !important;
  margin: 0 !important;
  padding: 0 !important;
  overflow: hidden !important;
}

html[data-hero-os-visual] .top,
html[data-hero-os-visual] .toolbar,
html[data-hero-os-visual] .context-actions,
html[data-hero-os-visual] .community-context-bar,
html[data-hero-os-visual] .student-head,
html[data-hero-os-visual] .modal-actions,
html[data-hero-os-visual] .community-v3-actions{
  gap: 10px;
  align-items: center;
}

html[data-hero-os-visual] .btn,
html[data-hero-os-visual] button.btn,
html[data-hero-os-visual] a.btn{
  min-height: 42px;
  border-radius: 999px;
  white-space: nowrap;
  transform: translateZ(0);
  transition: background var(--hero-rc-transition), border-color var(--hero-rc-transition), color var(--hero-rc-transition), opacity var(--hero-rc-transition), transform var(--hero-rc-transition);
}

html[data-hero-os-visual] .btn:hover{
  transform: translateY(-1px);
}

html[data-hero-os-visual] .btn:active{
  transform: translateY(0);
}

html[data-hero-os-visual] input,
html[data-hero-os-visual] textarea,
html[data-hero-os-visual] select{
  max-width: 100%;
  min-height: 44px;
}

html[data-hero-os-visual] textarea{
  resize: vertical;
}

html[data-hero-os-visual] img,
html[data-hero-os-visual] video,
html[data-hero-os-visual] canvas,
html[data-hero-os-visual] svg{
  max-width: 100%;
}

html[data-hero-os-visual] .student-list-card,
html[data-hero-os-visual] .student-head,
html[data-hero-os-visual] .student-name,
html[data-hero-os-visual] .student-title,
html[data-hero-os-visual] .aluna-nome,
html[data-hero-os-visual] [data-student-name]{
  min-width: 0;
}

html[data-hero-os-visual] .student-list-card strong,
html[data-hero-os-visual] .student-head strong,
html[data-hero-os-visual] .student-name,
html[data-hero-os-visual] .student-title,
html[data-hero-os-visual] .aluna-nome,
html[data-hero-os-visual] [data-student-name]{
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

html[data-hero-os-visual] .panel,
html[data-hero-os-visual] .card,
html[data-hero-os-visual] .workout-card,
html[data-hero-os-visual] .exercise,
html[data-hero-os-visual] .student-ex,
html[data-hero-os-visual] .community-v3-post,
html[data-hero-os-visual] .community-v3-card,
html[data-hero-os-visual] .community-v3-stat,
html[data-hero-os-visual] .coach-kpi,
html[data-hero-os-visual] .metric-card{
  border-color: var(--hero-rc-line);
  box-shadow: none;
}

html[data-hero-os-visual] .modal,
html[data-hero-os-visual] .modal-overlay{
  overflow-x: hidden;
}

html[data-hero-os-visual] .modal-box{
  width: min(720px, calc(100vw - 32px));
  max-height: calc(100dvh - 32px);
  overflow: auto;
}

html[data-hero-os-visual] .student-ai-float{
  position: fixed;
  right: clamp(14px, 3vw, 24px);
  bottom: clamp(14px, 3vw, 24px);
  z-index: 60;
  max-width: min(360px, calc(100vw - 28px));
}

html[data-hero-os-visual] .student-ai-panel{
  position: fixed;
  right: clamp(14px, 3vw, 24px);
  bottom: clamp(82px, 10vw, 96px);
  z-index: 70;
  width: min(420px, calc(100vw - 28px));
  max-height: min(620px, calc(100dvh - 112px));
  overflow: hidden;
}

html[data-hero-os-visual] .student-ai-panel.is-hidden,
html[data-hero-os-visual] .student-ai-float.is-hidden{
  display: none !important;
}

html[data-hero-os-visual] .student-ai-messages{
  max-height: min(420px, calc(100dvh - 260px));
  overflow: auto;
}

@media (prefers-reduced-motion: reduce){
  html[data-hero-os-visual] *,
  html[data-hero-os-visual] *::before,
  html[data-hero-os-visual] *::after{
    animation-duration: .001ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: .001ms !important;
  }
}

@media (max-width: 920px){
  html[data-hero-os-visual] .admin-grid,
  html[data-hero-os-visual] .admin-grid-fixed,
  html[data-hero-os-visual] .community-v3-board,
  html[data-hero-os-visual] .login-shell{
    grid-template-columns: 1fr !important;
  }

  html[data-hero-os-visual] .top,
  html[data-hero-os-visual] .toolbar,
  html[data-hero-os-visual] .context-actions,
  html[data-hero-os-visual] .community-context-bar{
    flex-wrap: wrap;
  }
}

@media (max-width: 640px){
  html[data-hero-os-visual] .wrap{
    width: min(100%, calc(100vw - 24px));
    padding-inline: 0;
  }

  html[data-hero-os-visual] h1{
    font-size: clamp(2rem, 11vw, 3.1rem);
  }

  html[data-hero-os-visual] .btn,
  html[data-hero-os-visual] button.btn,
  html[data-hero-os-visual] a.btn{
    width: 100%;
    justify-content: center;
  }

  html[data-hero-os-visual] .toolbar .btn,
  html[data-hero-os-visual] .context-actions .btn,
  html[data-hero-os-visual] .community-v3-actions .btn,
  html[data-hero-os-visual] .modal-actions .btn{
    width: auto;
    flex: 1 1 auto;
  }

  html[data-hero-os-visual] .student-ai-float{
    left: 12px;
    right: 12px;
    bottom: 12px;
    max-width: none;
  }

  html[data-hero-os-visual] .student-ai-panel{
    left: 12px;
    right: 12px;
    bottom: 78px;
    width: auto;
    max-height: calc(100dvh - 96px);
  }
}
