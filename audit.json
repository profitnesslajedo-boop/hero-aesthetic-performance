/* HERO OS — Refinamento por página V65
   Somente camada visual. Mantém intactos dados, Supabase, autenticação, IA, rotas e regras. */

:root{
  --v65-max:1240px;
  --v65-gap:clamp(18px,2vw,28px);
  --v65-deep:rgba(7,9,12,.78);
  --v65-glass:rgba(255,255,255,.035);
  --v65-line:rgba(255,255,255,.075);
  --v65-line-strong:rgba(255,255,255,.14);
  --v65-red:#a3192b;
  --v65-red-2:#d33749;
  --v65-text:#f7f8fb;
  --v65-muted:#8f98a8;
}

/* refinamento global: menos caixas, mais composição */
body[data-hero-visual="reset-v64"] .wrap,
body[data-hero-visual="reset-v64"] main.wrap{
  width:min(var(--v65-max),calc(100vw - 56px)) !important;
}

body[data-hero-visual="reset-v64"] section + section{
  margin-top:clamp(30px,4vw,64px) !important;
}

body[data-hero-visual="reset-v64"] .panel,
body[data-hero-visual="reset-v64"] .today-panel,
body[data-hero-visual="reset-v64"] .protocol,
body[data-hero-visual="reset-v64"] .selected-student-panel,
body[data-hero-visual="reset-v64"] .students-panel,
body[data-hero-visual="reset-v64"] .community-composer,
body[data-hero-visual="reset-v64"] .community-post,
body[data-hero-visual="reset-v64"] .community-side-card,
body[data-hero-visual="reset-v64"] .workout-card,
body[data-hero-visual="reset-v64"] .exercise,
body[data-hero-visual="reset-v64"] .lib,
body[data-hero-visual="reset-v64"] .quick-card,
body[data-hero-visual="reset-v64"] .student-ex,
body[data-hero-visual="reset-v64"] .metric-card{
  box-shadow:none !important;
}

/* página login */
body[data-hero-visual="reset-v64"] .login-screen{
  background:
    linear-gradient(90deg,rgba(5,6,7,.98) 0%,rgba(5,6,7,.92) 38%,rgba(5,6,7,.50) 100%),
    radial-gradient(circle at 18% 18%,rgba(211,55,73,.22),transparent 28%),
    url('https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=2200&q=88') center right/cover no-repeat !important;
}
body[data-hero-visual="reset-v64"] .login-shell{
  grid-template-columns:minmax(0,1fr) minmax(360px,.56fr) !important;
  min-height:calc(100vh - 64px) !important;
  align-items:center !important;
}
body[data-hero-visual="reset-v64"] .login-card{
  order:2 !important;
  align-self:center !important;
  max-width:460px !important;
  justify-self:end !important;
  padding:34px !important;
  background:rgba(8,10,13,.62) !important;
  border-color:rgba(255,255,255,.11) !important;
}
body[data-hero-visual="reset-v64"] .login-card h1{
  max-width:9.5ch !important;
  font-size:clamp(40px,4.6vw,70px) !important;
  line-height:.86 !important;
}
body[data-hero-visual="reset-v64"] .login-visual{
  order:1 !important;
  min-height:580px !important;
  justify-content:flex-end !important;
  background:transparent !important;
  border:0 !important;
  box-shadow:none !important;
  padding:0 !important;
}
body[data-hero-visual="reset-v64"] .login-visual .visual-copy{
  max-width:760px !important;
}
body[data-hero-visual="reset-v64"] .login-visual h2{
  font-size:clamp(52px,7vw,104px) !important;
  line-height:.86 !important;
  letter-spacing:-.085em !important;
  max-width:850px !important;
}
body[data-hero-visual="reset-v64"] .visual-cards{
  max-width:720px !important;
  margin-top:34px !important;
}
body[data-hero-visual="reset-v64"] .visual-card{
  min-height:132px !important;
  background:rgba(255,255,255,.035) !important;
  border-color:rgba(255,255,255,.075) !important;
}

/* topbar premium */
body[data-hero-visual="reset-v64"] .top{
  width:min(var(--v65-max),calc(100vw - 56px)) !important;
  padding:12px 14px 12px 18px !important;
  background:rgba(7,9,12,.70) !important;
  border-color:rgba(255,255,255,.09) !important;
}
body[data-hero-visual="reset-v64"] .top nav{
  justify-content:flex-end !important;
}
body[data-hero-visual="reset-v64"] .top .btn{
  min-height:36px !important;
}

/* aberturas das páginas */
body[data-hero-visual="reset-v64"] main.wrap > .hero,
body[data-hero-visual="reset-v64"] .student-view > .hero,
body[data-hero-visual="reset-v64"] .community-hero{
  min-height:clamp(280px,36vw,440px) !important;
  padding:clamp(34px,5vw,74px) !important;
  border-radius:42px !important;
  background:
    linear-gradient(115deg,rgba(255,255,255,.075),rgba(255,255,255,.018) 52%,rgba(163,25,43,.16)),
    radial-gradient(circle at 82% 18%,rgba(211,55,73,.22),transparent 32%) !important;
}
body[data-hero-visual="reset-v64"] main.wrap > .hero h1,
body[data-hero-visual="reset-v64"] .student-view > .hero h1,
body[data-hero-visual="reset-v64"] .community-hero h1{
  max-width:850px !important;
  font-size:clamp(46px,6vw,92px) !important;
}
body[data-hero-visual="reset-v64"] main.wrap > .hero p,
body[data-hero-visual="reset-v64"] .student-view > .hero p,
body[data-hero-visual="reset-v64"] .community-hero p{
  max-width:680px !important;
}

/* painel treinador */
body[data-hero-visual="reset-v64"] .operator-action-hub{
  grid-template-columns:minmax(0,1.15fr) minmax(0,.85fr) !important;
  gap:var(--v65-gap) !important;
}
body[data-hero-visual="reset-v64"] .operator-action-card{
  min-height:250px !important;
  padding:28px !important;
  border-radius:32px !important;
  align-content:end !important;
}
body[data-hero-visual="reset-v64"] .operator-action-card.primary{
  background:
    linear-gradient(150deg,rgba(163,25,43,.20),rgba(255,255,255,.035) 54%,rgba(255,255,255,.018)) !important;
}
body[data-hero-visual="reset-v64"] .operator-action-card h3{
  font-size:clamp(28px,3vw,48px) !important;
}
body[data-hero-visual="reset-v64"] .control-metrics{
  grid-template-columns:repeat(5,minmax(0,1fr)) !important;
  border-top:1px solid var(--v65-line) !important;
  border-bottom:1px solid var(--v65-line) !important;
  padding:18px 0 !important;
  gap:0 !important;
}
body[data-hero-visual="reset-v64"] .metric-card{
  min-height:104px !important;
  border:0 !important;
  border-radius:0 !important;
  background:transparent !important;
  padding:10px 20px !important;
  border-right:1px solid rgba(255,255,255,.055) !important;
}
body[data-hero-visual="reset-v64"] .metric-card:last-child{border-right:0 !important;}
body[data-hero-visual="reset-v64"] .metric-card strong{
  font-size:clamp(24px,2.8vw,44px) !important;
}
body[data-hero-visual="reset-v64"] .admin-grid-fixed{
  grid-template-columns:minmax(280px,330px) minmax(0,1fr) !important;
  gap:var(--v65-gap) !important;
}
body[data-hero-visual="reset-v64"] .students-panel,
body[data-hero-visual="reset-v64"] .selected-student-panel{
  background:transparent !important;
  border-color:var(--v65-line) !important;
}
body[data-hero-visual="reset-v64"] .students-panel{
  border-left:0 !important;
  border-top:0 !important;
  border-bottom:0 !important;
  border-radius:0 !important;
  padding:6px 22px 6px 0 !important;
}
body[data-hero-visual="reset-v64"] .selected-student-panel{
  padding:28px !important;
  border-radius:34px !important;
}
body[data-hero-visual="reset-v64"] .student-list-card{
  border-radius:20px !important;
  background:rgba(255,255,255,.025) !important;
}
body[data-hero-visual="reset-v64"] .workout-card{
  border-radius:24px !important;
  background:rgba(255,255,255,.028) !important;
}

/* prescrição */
body[data-hero-visual="reset-v64"] .hero-workout-timer-card{
  border-radius:999px !important;
  padding:16px 18px 16px 22px !important;
  background:rgba(255,255,255,.035) !important;
  border-color:var(--v65-line) !important;
  margin-bottom:24px !important;
}
body[data-hero-visual="reset-v64"] #heroWorkoutTimer{
  font-size:clamp(28px,3vw,44px) !important;
}
body[data-hero-visual="reset-v64"] .quick-prescription{
  margin-top:22px !important;
  background:rgba(255,255,255,.025) !important;
  border-radius:28px !important;
}
body[data-hero-visual="reset-v64"] .quick-results,
body[data-hero-visual="reset-v64"] .library-grid{
  grid-template-columns:repeat(2,minmax(0,1fr)) !important;
}
body[data-hero-visual="reset-v64"] .quick-card,
body[data-hero-visual="reset-v64"] .lib,
body[data-hero-visual="reset-v64"] .exercise{
  border-radius:24px !important;
  background:rgba(255,255,255,.027) !important;
}
body[data-hero-visual="reset-v64"] .exercise-list{
  display:grid !important;
  grid-template-columns:repeat(2,minmax(0,1fr)) !important;
  gap:16px !important;
}
body[data-hero-visual="reset-v64"] .exercise{
  min-height:260px !important;
  align-content:space-between !important;
}
body[data-hero-visual="reset-v64"] .panel-title{
  margin-bottom:18px !important;
}

/* área da aluna */
body[data-hero-visual="reset-v64"] .student-view .control-metrics{
  grid-template-columns:repeat(5,minmax(0,1fr)) !important;
}
body[data-hero-visual="reset-v64"] .student-view .today-panel{
  padding:clamp(24px,3vw,34px) !important;
  border-radius:34px !important;
  background:
    linear-gradient(180deg,rgba(255,255,255,.05),rgba(255,255,255,.024)) !important;
}
body[data-hero-visual="reset-v64"] .student-view .protocol{
  background:transparent !important;
  border:0 !important;
  padding:0 !important;
}
body[data-hero-visual="reset-v64"] .student-view .protocol > .eyebrow,
body[data-hero-visual="reset-v64"] .student-view .protocol > h2,
body[data-hero-visual="reset-v64"] .student-view .protocol > p,
body[data-hero-visual="reset-v64"] .student-view .protocol > .note{
  margin-left:0 !important;
}
body[data-hero-visual="reset-v64"] .day{
  padding-top:26px !important;
  border-top:1px solid var(--v65-line) !important;
}
body[data-hero-visual="reset-v64"] .student-ex{
  border-radius:24px !important;
  background:rgba(255,255,255,.028) !important;
}
body[data-hero-visual="reset-v64"] .timer-box,
body[data-hero-visual="reset-v64"] .finish-box{
  border-radius:26px !important;
}
body[data-hero-visual="reset-v64"] .day-tabs{
  margin:16px 0 !important;
}

/* comunidade premium */
body[data-hero-visual="reset-v64"] .community-hero{
  background:
    linear-gradient(115deg,rgba(255,255,255,.07),rgba(255,255,255,.018) 55%,rgba(163,25,43,.15)),
    url('https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=2000&q=86') center right/cover no-repeat !important;
}
body[data-hero-visual="reset-v64"] .community-hero::after{
  content:"" !important;
  position:absolute !important;
  inset:0 !important;
  background:linear-gradient(90deg,rgba(5,6,7,.95),rgba(5,6,7,.68),rgba(5,6,7,.32)) !important;
  z-index:0 !important;
}
body[data-hero-visual="reset-v64"] .community-hero > *{z-index:1 !important;position:relative !important;}
body[data-hero-visual="reset-v64"] .community-shell{
  grid-template-columns:minmax(0,1.5fr) minmax(280px,.62fr) !important;
  gap:var(--v65-gap) !important;
}
body[data-hero-visual="reset-v64"] .community-composer{
  padding:22px !important;
  border-radius:30px !important;
  background:rgba(255,255,255,.03) !important;
}
body[data-hero-visual="reset-v64"] .community-post{
  padding:0 !important;
  overflow:hidden !important;
  border-radius:34px !important;
  background:rgba(255,255,255,.035) !important;
}
body[data-hero-visual="reset-v64"] .community-post-head,
body[data-hero-visual="reset-v64"] .community-content,
body[data-hero-visual="reset-v64"] .community-actions,
body[data-hero-visual="reset-v64"] .community-comments{
  padding-left:24px !important;
  padding-right:24px !important;
}
body[data-hero-visual="reset-v64"] .community-post-head{padding-top:22px !important;}
body[data-hero-visual="reset-v64"] .community-content{
  font-size:clamp(17px,1.8vw,22px) !important;
  line-height:1.58 !important;
  color:#fff !important;
}
body[data-hero-visual="reset-v64"] .community-image{
  border-radius:0 !important;
  border-left:0 !important;
  border-right:0 !important;
  aspect-ratio:16/10 !important;
}
body[data-hero-visual="reset-v64"] .community-actions{padding-top:2px !important;}
body[data-hero-visual="reset-v64"] .community-comments{padding-bottom:24px !important;}
body[data-hero-visual="reset-v64"] .community-comment{
  background:rgba(255,255,255,.03) !important;
  border-radius:18px !important;
}
body[data-hero-visual="reset-v64"] .community-side-card{
  border-radius:28px !important;
  background:rgba(255,255,255,.025) !important;
}

/* biblioteca */
body[data-hero-visual="reset-v64"] .filters{
  padding:10px !important;
  border:1px solid var(--v65-line) !important;
  border-radius:24px !important;
  background:rgba(255,255,255,.022) !important;
  margin-bottom:20px !important;
}
body[data-hero-visual="reset-v64"] .lib{
  min-height:250px !important;
  align-content:space-between !important;
}

/* modais e IA */
body[data-hero-visual="reset-v64"] .modal-box{
  border-radius:34px !important;
  background:rgba(10,12,16,.94) !important;
  border-color:rgba(255,255,255,.11) !important;
}
body[data-hero-visual="reset-v64"] .hero-ai-drawer{
  border-radius:34px !important;
  background:rgba(10,12,16,.94) !important;
}
body[data-hero-visual="reset-v64"] .hero-ai-msg{
  border-radius:20px !important;
}

/* eliminar sensação de template gerada por animações/efeitos chamativos */
body[data-hero-visual="reset-v64"] *,
body[data-hero-visual="reset-v64"] *::before,
body[data-hero-visual="reset-v64"] *::after{
  animation-duration:.001ms !important;
  animation-iteration-count:1 !important;
}
body[data-hero-visual="reset-v64"] .btn,
body[data-hero-visual="reset-v64"] .student-list-card,
body[data-hero-visual="reset-v64"] .day-pill,
body[data-hero-visual="reset-v64"] .hero-day-tab,
body[data-hero-visual="reset-v64"] input,
body[data-hero-visual="reset-v64"] textarea,
body[data-hero-visual="reset-v64"] select{
  transition:transform .18s ease,border-color .18s ease,background .18s ease,opacity .18s ease !important;
}

/* responsividade refinada */
@media (max-width:1180px){
  body[data-hero-visual="reset-v64"] .control-metrics,
  body[data-hero-visual="reset-v64"] .student-view .control-metrics{
    grid-template-columns:repeat(3,minmax(0,1fr)) !important;
  }
  body[data-hero-visual="reset-v64"] .metric-card:nth-child(3n){border-right:0 !important;}
  body[data-hero-visual="reset-v64"] .community-shell{grid-template-columns:1fr !important;}
  body[data-hero-visual="reset-v64"] .community-side{position:static !important;grid-template-columns:repeat(2,minmax(0,1fr)) !important;}
}
@media (max-width:980px){
  body[data-hero-visual="reset-v64"] .wrap,
  body[data-hero-visual="reset-v64"] main.wrap,
  body[data-hero-visual="reset-v64"] .top,
  body[data-hero-visual="reset-v64"] .login-shell{
    width:min(100vw - 28px,100%) !important;
  }
  body[data-hero-visual="reset-v64"] .login-shell,
  body[data-hero-visual="reset-v64"] .operator-action-hub,
  body[data-hero-visual="reset-v64"] .admin-grid-fixed,
  body[data-hero-visual="reset-v64"] .quick-results,
  body[data-hero-visual="reset-v64"] .library-grid,
  body[data-hero-visual="reset-v64"] .exercise-list,
  body[data-hero-visual="reset-v64"] .community-side{
    grid-template-columns:1fr !important;
  }
  body[data-hero-visual="reset-v64"] .login-card{justify-self:stretch !important;max-width:none !important;}
  body[data-hero-visual="reset-v64"] .login-visual{min-height:auto !important;}
  body[data-hero-visual="reset-v64"] .students-panel{position:static !important;border-right:0 !important;padding:0 !important;}
  body[data-hero-visual="reset-v64"] .control-metrics,
  body[data-hero-visual="reset-v64"] .student-view .control-metrics{
    grid-template-columns:repeat(2,minmax(0,1fr)) !important;
  }
  body[data-hero-visual="reset-v64"] .metric-card{border-right:0 !important;border-bottom:1px solid rgba(255,255,255,.055) !important;}
}
@media (max-width:660px){
  body[data-hero-visual="reset-v64"] .top{
    width:min(100vw - 20px,100%) !important;
    border-radius:26px !important;
  }
  body[data-hero-visual="reset-v64"] .top nav,
  body[data-hero-visual="reset-v64"] .toolbar,
  body[data-hero-visual="reset-v64"] .community-actions,
  body[data-hero-visual="reset-v64"] .student-head .toolbar{
    display:grid !important;
    grid-template-columns:1fr !important;
    width:100% !important;
  }
  body[data-hero-visual="reset-v64"] .btn,
  body[data-hero-visual="reset-v64"] .btn.small{
    width:100% !important;
  }
  body[data-hero-visual="reset-v64"] .hero,
  body[data-hero-visual="reset-v64"] .community-hero,
  body[data-hero-visual="reset-v64"] .print-head,
  body[data-hero-visual="reset-v64"] .student-head{
    border-radius:30px !important;
    padding:24px !important;
    min-height:300px !important;
  }
  body[data-hero-visual="reset-v64"] .control-metrics,
  body[data-hero-visual="reset-v64"] .student-view .control-metrics{
    grid-template-columns:1fr !important;
  }
  body[data-hero-visual="reset-v64"] .metric-card{padding:14px 0 !important;}
  body[data-hero-visual="reset-v64"] .modal{padding:12px !important;}
  body[data-hero-visual="reset-v64"] .modal-box{padding:22px !important;border-radius:26px !important;}
}
